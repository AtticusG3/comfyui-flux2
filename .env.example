# Hugging Face token; required when a selected pack uses gated Hugging Face models (e.g. klein-distilled).
HF_TOKEN=

# true = low VRAM tier (models-low / workflows-low), false = high tier
LOW_VRAM=false

# Automatically derive ComfyUI VRAM flags from LOW_VRAM when CLI_ARGS is empty
AUTO_VRAM_ARGS=true

# Override automatic VRAM flags. Example: --lowvram --reserve-vram 1.5 --cpu-vae
COMFYUI_VRAM_ARGS=

# Reserved VRAM in GB when LOW_VRAM=true and automatic VRAM args are enabled
RESERVE_VRAM_GB=1.2

# Optional NVFP4 mode for supported packs.
# Best current benefit: klein-distilled (official), plus allow-community Wan and firered-image-edit overrides.
# flux1-krea official NVFP4 URL is currently unverified; fallback remains FP8.
# NVFP4 keeps original NVFP4 model filenames and switches workflows accordingly.
# Recommended only on supported NVIDIA Blackwell + CUDA 13.0 stacks.
NVFP4_SUPPORTED=false
# NVFP4 source policy: official-only (default) or allow-community (experimental).
NVFP4_MODE=official-only

# Connectivity routing for restricted networks.
# Route modes: direct, proxy, smart-dns, vpn
# Per-provider routes support: inherit, direct, proxy, smart-dns, vpn
CONNECTIVITY_ROUTE_DEFAULT=direct
CONNECTIVITY_ROUTE_HUGGINGFACE=inherit
CONNECTIVITY_ROUTE_GITHUB=inherit
CONNECTIVITY_ROUTE_CIVITAI=inherit

# Global proxy URL fallback (used when route=proxy and provider proxy is not set).
# Examples: http://proxy.local:8080  socks5://127.0.0.1:1080
PROXY_URL=
# Optional provider-specific proxy URLs.
HUGGINGFACE_PROXY_URL=
GITHUB_PROXY_URL=
CIVITAI_PROXY_URL=

# Optional DNS resolvers for route=smart-dns (comma-separated).
# Passed to aria2 as --async-dns-server.
DNS_SERVERS=
# Optional provider-specific DNS resolvers.
HUGGINGFACE_DNS_SERVERS=
GITHUB_DNS_SERVERS=
CIVITAI_DNS_SERVERS=

# Fetch/reset ComfyUI and managed custom-node git repos on each startup.
# Uses staged sync (scripts/lib/git_sync.sh): fetch into staging, rsync on success;
# failed fetch leaves the live tree untouched - set false for faster restarts when refs are current.
COMFYUI_GIT_UPDATE=true

# When ./data/workflows already has JSON, still install bundled/URL workflows for selected packs.
RESEED_PACK_WORKFLOWS=true

# Install requirements for manual custom nodes found on the persisted volume.
# Default false keeps startup pack-managed and avoids stale/orphan nodes downgrading deps.
INSTALL_ORPHAN_NODE_REQS=false

# Extra ComfyUI CLI arguments. When set, automatic VRAM args are not added.
CLI_ARGS=

# Comma-separated pack selectors (use "none" for no pack downloads; base VRAM nodes still install).
# Available: klein-distilled, firered-image-edit, realvisxl, hunyuan-3d, flux1-krea, hunyuan-video, ace-step, ovis-image,
# newbie-image, flux2, z-image-turbo, z-image-base, z-image-anime, qwen-image-edit-2511, wan-2-2, sdxl-lightning, sdxl-editing, ernie-image, hidream-o1, vram-utils (deprecated no-op)
MODELS_DOWNLOAD=none

# Timezone (optional)
TZ=UTC
