# Hugging Face token; required for klein-distilled, optional for other packs
HF_TOKEN=

# Civitai API token for Civicomfy model downloads (optional)
# Get your token at: https://civitai.com/user/account
CIVITAI_API_KEY=

# true = low VRAM tier (models-low / workflows-low), false = high tier
LOW_VRAM=false

# Automatically derive ComfyUI VRAM flags from LOW_VRAM when CLI_ARGS is empty
AUTO_VRAM_ARGS=true

# Override automatic VRAM flags. Example: --lowvram --reserve-vram 1.5 --cpu-vae
COMFYUI_VRAM_ARGS=

# Reserved VRAM in GB when LOW_VRAM=true and automatic VRAM args are enabled
RESERVE_VRAM_GB=1.2

# Optional NVFP4 mode for supported packs.
# Best current benefit: klein-distilled (official), plus allow-community Wan overrides.
# flux1-krea official NVFP4 URL is currently unverified; fallback remains FP8.
# NVFP4 keeps original NVFP4 model filenames and switches workflows accordingly.
# Recommended only on supported NVIDIA Blackwell + CUDA 13.0 stacks.
NVFP4_SUPPORTED=false
# NVFP4 source policy: official-only (default) or allow-community (experimental).
NVFP4_MODE=official-only

# Extra ComfyUI CLI arguments. When set, automatic VRAM args are not added.
CLI_ARGS=

# Comma-separated pack selectors
# Available: klein-distilled, hunyuan-3d, flux1-krea, hunyuan-video, ace-step, ovis-image, newbie-image,
# trellis2-gguf, wan-2-2, sdxl-lightning, vram-utils
MODELS_DOWNLOAD=klein-distilled

# Timezone (optional)
TZ=UTC
